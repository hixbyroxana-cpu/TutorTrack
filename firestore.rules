rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsIncomingDocument() {
      return signedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    function ownsStoredDocument() {
      return signedIn() && resource.data.ownerId == request.auth.uid;
    }

    function keepsOwner() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    match /students/{studentId} {
      allow create: if ownsIncomingDocument();
      allow read, delete: if ownsStoredDocument();
      allow update: if ownsStoredDocument() && keepsOwner();
    }

    match /lessons/{lessonId} {
      allow create: if ownsIncomingDocument();
      allow read, delete: if ownsStoredDocument();
      allow update: if ownsStoredDocument() && keepsOwner();
    }

    match /targets/{targetId} {
      allow create: if ownsIncomingDocument();
      allow read, delete: if ownsStoredDocument();
      allow update: if ownsStoredDocument() && keepsOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
